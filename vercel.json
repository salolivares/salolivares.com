{
  "headers": [
    {
      "source": "/giscus/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/script.js",
      "destination": "https://umami.salolivares.com/script.js"
    },
    {
      "source": "/api/submit",
      "destination": "https://umami.salolivares.com/api/submit"
    }
  ]
}
