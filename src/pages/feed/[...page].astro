---
import type { GetStaticPaths, InferGetStaticPropsType } from 'astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import FeedItem from '@/components/FeedItem.astro';
import Pagination from '@/components/Pagination.astro';
import { getFeedItems, getPermalink, renderFeedItem, FEED_TYPES } from '@/lib/feed';

export const getStaticPaths = (async ({ paginate }) => {
  const items = await getFeedItems();
  return paginate(items, { pageSize: 10 });
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;
const { page } = Astro.props as Props;

const renderedItems = await Promise.all(
  page.data.map(async (item) => {
    const { Content } = await renderFeedItem(item);
    return { ...item, Content };
  }),
);
---

<BaseLayout title="Feed">
  <h1 class="sr-only">Feed</h1>

  <nav class="mt-6 flex gap-3 text-sm" aria-label="Feed filters">
    <span class="text-accent-blue">[all]</span>
    {FEED_TYPES.map((type) => (
      <a
        href={`/feed/${type}`}
        class="hover:text-accent-blue no-underline"
        data-astro-prefetch
      >
        [{type}]
      </a>
    ))}
  </nav>

  <section class="mt-6">
    {renderedItems.map(({ Content, ...item }) => (
      <FeedItem pubDate={item.pubDate} type={item.type} permalink={getPermalink(item)}>
        <Content />
      </FeedItem>
    ))}
  </section>

  <Pagination
    prevUrl={page.url.prev}
    nextUrl={page.url.next}
    currentPage={page.currentPage}
    lastPage={page.lastPage}
  />
</BaseLayout>
