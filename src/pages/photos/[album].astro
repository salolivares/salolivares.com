---
import RemoteImage from '@/components/RemoteImage.astro';
import AlbumLayout from '@/layouts/AlbumLayout.astro';
import type { GetStaticPaths, InferGetStaticPropsType } from 'astro';
import { getCollection } from 'astro:content';

export const getStaticPaths = (async () => {
  const travel = await getCollection('travel');
  const series = await getCollection('series');
  const entries = [
    ...travel.map((album) => ({ album, kind: 'travel' as const })),
    ...series.map((album) => ({ album, kind: 'series' as const })),
  ];
  return entries.map(({ album, kind }) => ({
    params: { album: album.id },
    props: { album, kind },
  }));
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;
const { album, kind } = Astro.props;
const { images } = album.data;
---

<AlbumLayout album={album} kind={kind}>
  <div class="flex flex-col items-center">
    {
      images.map((image, i) => (
        <div class="flex min-h-screen max-w-screen-lg flex-col justify-center">
          <RemoteImage
            src={`${album.id}/${image.id}`}
            alt={image.name ?? 'Untitled'}
            loading={i === 0 ? 'eager' : 'lazy'}
            fetchpriority={i === 0 ? 'high' : undefined}
          />
          <div class="mt-3 text-right text-base font-semibold">{image.name ?? 'Untitled'}</div>
        </div>
      ))
    }
    {
      // Chikis Tribute
      album.id === 'chikis' && (
        <div class="flex min-h-screen max-w-screen-lg flex-col justify-center font-serif">
          <div class="text-lg">she will be missed.</div>
          <div class="text-sm">2010 &ndash; 2024</div>
        </div>
      )
    }
    <div class="mt-24 flex min-h-96 flex-col items-center">
      <a
        href="/photos"
        data-astro-prefetch="viewport"
        class="hover:text-accent-blue no-underline"
      >
        [back to albums]
      </a>
    </div>
  </div>
</AlbumLayout>
